// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  // Optional role so you can distinguish admin/shop owner vs customers
  role      UserRole @default(CUSTOMER)

  orders    Order[]
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum ClothType {
  SILK
  COTTON
  LINEN
  GEORGETTE
  CHIFFON
  KANJIVARAM
  BANARASI
  TUSSAR
  ORGANZA
  OTHER
}

enum Occasion {
  WEDDING
  FESTIVE
  CASUAL
  OFFICE
  BRIDAL
  PARTY
  GIFTING
  OTHER
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
}

model Product {
  id             String      @id @default(uuid())
  name           String
  slug           String      @unique
  description    String?
  priceInPaise   Int         // store in smallest currency unit (e.g. paise)
  inStock        Boolean     @default(true)
  stockQuantity  Int         @default(0)
  clothType      ClothType
  occasion       Occasion?
  isSpecial      Boolean     @default(false) // highlight special / featured sarees
  mainImageUrl   String?
  thumbnailUrl   String?
  color          String?
  pattern        String?     // e.g. zari, checks, floral, temple border
  blouseIncluded Boolean     @default(true)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  categoryId     String
  category       Category    @relation(fields: [categoryId], references: [id])

  images         ProductImage[]
  orderItems     OrderItem[]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id        String      @id @default(uuid())
  status    OrderStatus @default(PENDING)
  totalPaise Int

  userId    String?
  user      User?       @relation(fields: [userId], references: [id])

  guestEmail String?
  guestName  String?
  guestPhone String?

  shippingLine1   String
  shippingCity    String
  shippingState   String?
  shippingPostal  String?
  shippingCountry String? @default("India")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  priceInPaise Int
  productName  String

  @@index([orderId])
  @@index([productId])
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  altText   String?
  position  Int      @default(0)

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

/// Homepage hero carousel — managed in admin.
model HeroSlide {
  id        String   @id @default(uuid())
  imageUrl  String
  altText   String?
  linkUrl   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum HomeGridSection {
  WEDDING_EDIT
  SHOP_BY_PRICE
  CRAFTS
  SHOP_BY_OCCASION
}

/// Promo tiles (wedding edit, shop by price, crafts, occasions) — managed in admin.
model HomeGridItem {
  id        String          @id @default(uuid())
  section   HomeGridSection
  title     String
  imageUrl  String
  linkUrl   String?
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([section, sortOrder])
}

/// Single row: section titles + about copy + about image.
model SiteConfig {
  id                    String   @id @default("default")
  weddingEditTitle      String   @default("Your Wedding Edit")
  shopByPriceTitle      String   @default("Shop by Price")
  craftsTitle           String   @default("Discover timeless crafts")
  shopByOccasionTitle   String   @default("Shop by Occasion")
  specialsTitle         String   @default("Special picks")
  aboutTitle            String   @default("About Us")
  aboutBody             String   @default("") @db.Text
  aboutImageUrl         String?
  updatedAt             DateTime @updatedAt
}